PORT=5001
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/worktrust
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRE=7d
NODE_ENV=production
LOCAL_IP=localhost
FRONTEND_URL=http://localhost:5001
USE_MOCK_DIGILOCKER=true
DIGILOCKER_DEMO=true
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=
DIGILOCKER_BASE_URL=
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Google Sign-In (FREE — from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Fast2SMS OTP (₹50 free credits — from fast2sms.com)
# Leave empty to use mock OTP mode (accepts "123456")
FAST2SMS_API_KEY=

# Firebase Phone Auth Configuration (10,000 Free OTPs/Month globally)
# Leave empty to use Fast2SMS or Mock OTP mode.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_COOLDOWN_SECONDS=60

